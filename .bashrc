# Clear screen on start
clear

# Colors
RED='\[\033[1;31m\]'
WHITE='\[\033[1;37m\]'
RESET='\[\033[0m\]'

# Custom prompt (username@host:dir)
PS1="${RED}‚öĒ ${WHITE}\u@\h ${RED}‚ěú ${WHITE}\w ${RED}# ${RESET}"

# Aliases
alias ll='ls -alF'
alias cls='clear'
alias mongo='mongosh'

